@page
@model RegisterModel

<div class="card border-0 mt-4">
    <div class="card-header @(Model.Input.Id == null ? "bg-success" : "bg-warning") ml-0 py-4">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="py-2 text-white">
                    @(Model.Input.Id == null ? "Registrar Usuario" : "Editar Usuario")
                </h2>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <div class="row pt-3">
            <div class="col-md-12">
                <form id="registerForm" method="post" asp-route-id="@Model.Input.Id" class="row">
                    <input type="hidden" asp-for="Input.Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3 col-md-12">
                        <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                        <label asp-for="Input.Email" class="text-muted">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    @if (Model.Input.Id == null)
                    {
                        <div class="form-floating mb-3 col-md-6">
                            <input asp-for="Input.Password" class="form-control" placeholder="password" />
                            <label asp-for="Input.Password" class="text-muted">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3 col-md-6">
                            <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="password" />
                            <label asp-for="Input.ConfirmPassword" class="text-muted">Confirm Password</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>
                    }

                    <div class="form-floating mb-3">
                        <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select">
                            <option disabled selected>--Seleccionar Rol--</option>
                        </select>
                    </div>

                    <div class="d-flex justify-content-center">
                        <button id="registerSubmit" type="submit" class="btn btn-primary mx-2">
                            @(Model.Input.Id == null ? "Registrar Usuario" : "Guardar Cambios")
                        </button>

                        <a asp-area="Ingeniero" asp-controller="Usuarios" asp-action="Index" class="btn btn-secondary mx-2">
                            Volver a la lista
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
