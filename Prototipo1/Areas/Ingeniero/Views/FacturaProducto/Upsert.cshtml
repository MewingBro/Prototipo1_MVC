@model Prototipo1.Models.ViewModels.FacturaProductoVM

<form asp-action="Upsert" asp-controller="FacturaProducto" method="post" class="row" enctype="multipart/form-data">
    <input asp-for="FacturaProducto.IdFactura" value="@ViewBag.IdFactura" hidden />
    <input asp-for="FacturaProducto.IdFacturaProducto" hidden />

    <div class="col-10">
        <div class="border p-3 mt-4">
            <h2 class="text-primary">
                @(Model.FacturaProducto.IdFacturaProducto != 0 ? "Actualizar" : "Crear") Detalle
            </h2>

            <!-- Producto -->
            <div class="mb-3 row p-1">
                <label>Producto</label>
                <div class="input-group">
                    <input type="text" id="productoNombre" class="form-control" readonly />
                    <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#buscarProductoModal">
                        Buscar
                    </button>
                </div>
                <input asp-for="FacturaProducto.IdProducto" id="productoId" hidden />
            </div>

            <div class="mb-3 row p-1">
                <label>Código</label>
                <input type="text" id="productoCodigo" class="form-control" readonly />
            </div>

            <div class="mb-3 row p-1">
                <label>Familia</label>
                <input type="text" id="productoFamilia" class="form-control" readonly />
            </div>

            <div class="mb-3 row p-1">
                <label>Unidad</label>
                <input type="text" id="productoUnidad" class="form-control" readonly />
            </div>

            <div class="mb-3 row p-1">
                <label>Media Aritmética</label>
                <input type="text" id="productoMedia" class="form-control" readonly />
            </div>

            <div class="mb-3 row p-1">
                <label>Descripción</label>
                <textarea id="productoDescripcion" class="form-control" readonly></textarea>
            </div>

            <!-- Cantidad y EntregadoA -->
            <div class="mb-3 row p-1">
                <label asp-for="FacturaProducto.CantidadAumentada">Cantidad Aumentada</label>
                <input asp-for="FacturaProducto.CantidadAumentada" class="form-control" />
                <span asp-validation-for="FacturaProducto.CantidadAumentada" class="text-danger"></span>
            </div>

            <div class="mb-3 row p-1">
                <label asp-for="FacturaProducto.EntregadoA">Entregado A</label>
                <input asp-for="FacturaProducto.EntregadoA" class="form-control" />
                <span asp-validation-for="FacturaProducto.EntregadoA" class="text-danger"></span>
            </div>

            <!-- Botones -->
            <div class="row">
                <div class="col-6 col-md-3">
                    <button type="submit" class="btn btn-primary form-control">
                        @(Model.FacturaProducto.IdFacturaProducto != 0 ? "Actualizar" : "Agregar")
                    </button>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-controller="FacturaProducto" asp-action="Index" asp-route-IdFactura="@ViewBag.IdFactura" class="btn btn-outline-secondary form-control">
                        Volver a la lista de Productos
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Partial para buscar productos -->
@await Html.PartialAsync("_BuscarProducto", new List<Prototipo1.Models.Producto>())
