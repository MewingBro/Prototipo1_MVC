@model List<FacturaProducto>
<partial name="_Notification" />
<div class="container">

    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">Productos de Factura</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="FacturaProducto" asp-action="Upsert" asp-route-IdFactura="@ViewBag.IdFactura" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Agregar Producto
            </a>
        </div>
    </div>


    <table class="table table-bordered table-stripped">
        <thead>
            <tr>
                <th>
                    Id de factura
                </th>
                <th>
                    Producto
                </th>
                <th>
                    Cantidad Aumentada
                </th>
                <th>
                    Entregado A
                </th>
                <th>

                </th>

            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model.OrderBy(u => u.IdFactura))
            {
                <tr>
                    <td>
                        @obj.IdFactura
                    </td>
                    <td>
                        @obj.Producto.NombreProducto
                    </td>
                    <td>
                        @obj.CantidadAumentada
                    </td>
                    <td>
                        @obj.EntregadoA
                    </td>

                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="FacturaProducto" asp-action="Upsert" asp-route-IdFactura="@ViewBag.IdFactura" asp-route-IdFacturaProducto="@obj.IdFacturaProducto" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil">Editar detalle</i>
                            </a>
                            <a asp-controller="FacturaProducto" asp-action="Borrar" asp-route-IdFactura="@ViewBag.IdFactura" asp-route-IdFacturaProducto="@obj.IdFacturaProducto" class="btn btn-danger mx-2">
                                <i class="bi bi-trash3">Borrar detalle</i>
                            </a>

                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>



        <div class="col-6 text-end">
            <form asp-controller="FacturaProducto" asp-action="TerminarFactura" asp-route-IdFactura="@ViewBag.IdFactura" method="post" style="display:inline;">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Terminar Factura y agregar Productos al inventario
                </button>
            </form>
        </div>


</div>
