@model List<Producto>
<partial name="_Notification" />

<div class="container mt-4">
    <div class="row align-items-center mb-3">
        <div class="col-md-6">
            <h2 class="text-primary mb-0">
                <i class="bi bi-box-seam me-2"></i>Lista de Productos
            </h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-controller="Producto" asp-action="Upsert" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> Agregar Producto
            </a>
        </div>
    </div>

    <!-- 🔍 Filtros -->
    <form method="get" asp-action="Index" class="row g-2 align-items-end mb-4">
        <div class="col-md-4">
            <label class="form-label fw-bold">Buscar</label>
            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control shadow-sm" placeholder="Nombre o código..." />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">Familia</label>
            <select name="idFamilia" class="form-select shadow-sm">
                <option value="">-- Todas --</option>
                @foreach (var fam in ViewBag.FamiliaList)
                {
                    <option value="@fam.Value" selected="@(ViewBag.IdFamilia?.ToString() == fam.Value ? "selected" : null)">
                        @fam.Text
                    </option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">Unidad</label>
            <select name="idUnidad" class="form-select shadow-sm">
                <option value="">-- Todas --</option>
                @foreach (var uni in ViewBag.UnidadList)
                {
                    <option value="@uni.Value" selected="@(ViewBag.IdUnidad?.ToString() == uni.Value ? "selected" : null)">
                        @uni.Text
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2 d-flex justify-content-end gap-2">
            <button type="submit" class="btn btn-warning shadow-sm w-100">
                <i class="bi bi-search"></i> Filtrar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm w-100">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        </div>
    </form>

    <!-- Tabla -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-bordered table-hover align-middle text-center">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Media Aritmética</th>
                    <th>Familia</th>
                    <th>Unidad</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-3">
                            No se encontraron productos que coincidan con los filtros.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var obj in Model)
                    {
                        <tr>
                            <td>@obj.IdProducto</td>
                            <td>@obj.CodigoProducto</td>
                            <td>@obj.NombreProducto</td>
                            <td>@obj.Descripcion</td>
                            <td>@obj.MediaAritmetica</td>
                            <td>@obj.Familia?.NombreFamilia</td>
                            <td>@obj.Unidad?.NombreUnidad</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-controller="Producto" asp-action="Upsert" asp-route-IdProducto="@obj.IdProducto" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="Producto" asp-action="Borrar" asp-route-IdProducto="@obj.IdProducto" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- 📄 Paginación -->
    @{
        int page = ViewBag.Page;
        int pageSize = ViewBag.PageSize;
        int total = ViewBag.TotalProductos;
        int totalPages = (int)Math.Ceiling((double)total / pageSize);
    }

    <nav class="mt-3">
        <ul class="pagination justify-content-center pagination-sm">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString"
                       asp-route-idFamilia="@ViewBag.IdFamilia"
                       asp-route-idUnidad="@ViewBag.IdUnidad">
                        @i
                    </a>
                </li>
            }
        </ul>
    </nav>
</div>

