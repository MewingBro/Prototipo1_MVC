@model Prototipo1.Models.ViewModels.ProductoVM

<div class="container py-4">
    <form method="post" class="row shadow-sm border rounded p-4 bg-light" enctype="multipart/form-data">
        <!-- Campos ocultos -->
        <input asp-for="Producto.IdProducto" hidden />
        <input asp-for="Producto.ImageURL" hidden />

        <!-- Título -->
        <div class="text-center mb-4">
            <h2 class="text-primary fw-bold">
                @(Model.Producto.IdProducto != 0 ? "Actualizar Producto" : "Crear Producto")
            </h2>
            <p class="text-muted mb-0">
                Complete los datos del producto y seleccione su familia, unidad y una imagen representativa.
            </p>
        </div>

        <!-- Formulario principal -->
        <div class="row">
            <div class="col-lg-9">
                <div class="mb-3">
                    <label asp-for="Producto.CodigoProducto" class="form-label fw-semibold">Código Producto</label>
                    <input asp-for="Producto.CodigoProducto" class="form-control" placeholder="Ingrese el código del producto" />
                    <span asp-validation-for="Producto.CodigoProducto" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Producto.NombreProducto" class="form-label fw-semibold">Nombre Producto</label>
                    <input asp-for="Producto.NombreProducto" class="form-control" placeholder="Ingrese el nombre del producto" />
                    <span asp-validation-for="Producto.NombreProducto" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Producto.Descripcion" class="form-label fw-semibold">Descripción</label>
                    <textarea asp-for="Producto.Descripcion" class="form-control" rows="2" placeholder="Ingrese una descripción breve"></textarea>
                    <span asp-validation-for="Producto.Descripcion" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Producto.MediaAritmetica" class="form-label fw-semibold">Media Aritmética</label>
                    <input asp-for="Producto.MediaAritmetica" class="form-control" placeholder="Ingrese el valor medio" />
                    <span asp-validation-for="Producto.MediaAritmetica" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Familia</label>
                    <select asp-for="Producto.IdFamilia" asp-items="@Model.FamiliaList" class="form-select">
                        <option disabled selected>--- Seleccionar Familia ---</option>
                    </select>
                    <span asp-validation-for="Producto.IdFamilia" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Unidad</label>
                    <select asp-for="Producto.IdUnidad" asp-items="@Model.UnidadList" class="form-select">
                        <option disabled selected>--- Seleccionar Unidad ---</option>
                    </select>
                    <span asp-validation-for="Producto.IdUnidad" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Producto.ImageURL" class="form-label fw-semibold">Imagen del Producto</label>
                    <input type="file" name="file" class="form-control" />
                    <span asp-validation-for="Producto.ImageURL" class="text-danger"></span>
                </div>

                <!-- Botones -->
                <div class="d-flex gap-3">
                    @if (Model.Producto.IdProducto != 0)
                    {
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save"></i> Actualizar
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-plus-circle"></i> Agregar
                        </button>
                    }

                    <a asp-controller="Producto" asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left-circle"></i> Volver a la lista
                    </a>
                </div>
            </div>

            <!-- Imagen lateral -->
            <div class="col-lg-3 d-flex align-items-start justify-content-center mt-4 mt-lg-0">
                <div class="text-center">
                    <img src="@Model.Producto.ImageURL"
                         class="img-fluid rounded border"
                         alt="Imagen del producto"
                         style="max-height: 200px; object-fit: contain;" />
                    <p class="text-muted small mt-2">Vista previa del producto</p>
                </div>
            </div>
        </div>
    </form>
</div>
