@model Prototipo1.Models.ViewModels.NivelVM

<div class="container py-4">
    <form method="post" enctype="multipart/form-data" class="shadow-sm border rounded p-4 bg-light">
        <!-- ID oculto -->
        <input asp-for="Nivel.IdNivel" hidden />
        <input asp-for="Nivel.IdProyecto" value="@Context.Session.GetInt32("IdProyecto")" hidden />

        <!-- Encabezado -->
        <div class="text-center mb-4">
            <h2 class="text-primary fw-bold">
                <i class="bi bi-layers"></i>
                @(Model.Nivel.IdNivel != 0 ? "Editar Nivel" : "Agregar Nuevo Nivel")
            </h2>
            <p class="text-muted mb-0">
                Complete la información requerida para @(Model.Nivel.IdNivel != 0 ? "modificar" : "registrar") un nivel del proyecto.
            </p>
        </div>

        <!-- Campo de nombre -->
        <div class="mb-3">
            <label asp-for="Nivel.NombreNivel" class="form-label fw-semibold"></label>
            <input asp-for="Nivel.NombreNivel" class="form-control" placeholder="Ingrese el nombre del nivel..." />
            <span asp-validation-for="Nivel.NombreNivel" class="text-danger small"></span>
        </div>

        <!-- Botones de acción -->
        <div class="d-flex justify-content-center gap-3 mt-4">
            @if (Model.Nivel.IdNivel != 0)
            {
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-pencil-square"></i> Actualizar
                </button>
            }
            else
            {
                <button type="submit" class="btn btn-success px-4">
                    <i class="bi bi-plus-circle"></i> Agregar
                </button>
            }

            <a asp-controller="Nivel" asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left-circle"></i> Volver a la lista
            </a>
        </div>
    </form>
</div>
