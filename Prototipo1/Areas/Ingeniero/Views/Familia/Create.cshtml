@model Familia

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">
                Agregar Familia
            </h2>
        </div>
        <div class="mb-3 row p-1">
            <label asp-for=NombreFamilia class="p-0"></label>
            <input asp-for="NombreFamilia" class="form-control"/>
            <span asp-validation-for="NombreFamilia" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-primary form-control">Agregar</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Familia" asp-action="Index" class="btn btn-outline-secondary form-control">
                    Volver a la lista
                </a>
            </div>
        </div>        
    </div>
</form>
