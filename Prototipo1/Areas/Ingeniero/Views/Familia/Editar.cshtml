@model Familia

<div class="container py-4">
    <form method="post" class="shadow-sm border rounded p-4 bg-light">
        <!-- ID oculto -->
        <input asp-for="IdFamilia" hidden />

        <!-- Encabezado -->
        <div class="text-center mb-4">
            <h2 class="text-primary fw-bold">
                <i class="bi bi-pencil-square"></i> Editar Familia
            </h2>
            <p class="text-muted mb-0">
                Modifique la información de la familia seleccionada y guarde los cambios.
            </p>
        </div>

        <!-- Campo: Nombre de la familia -->
        <div class="mb-4">
            <label asp-for="NombreFamilia" class="form-label fw-semibold"></label>
            <input asp-for="NombreFamilia" class="form-control" placeholder="Ingrese el nuevo nombre de la familia..." />
            <span asp-validation-for="NombreFamilia" class="text-danger small"></span>
        </div>

        <!-- Botones de acción -->
        <div class="d-flex justify-content-center gap-3 mt-3">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-save"></i> Guardar Cambios
            </button>
            <a asp-controller="Familia" asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left-circle"></i> Cancelar
            </a>
        </div>
    </form>
</div>
