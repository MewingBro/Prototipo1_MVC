@model Familia

<div class="container py-4">
    <form method="post" class="shadow-sm border rounded p-4 bg-light">
        <input asp-for="IdFamilia" type="hidden" />

        <!-- Encabezado -->
        <div class="text-center mb-4">
            <h2 class="text-danger fw-bold">
                <i class="bi bi-exclamation-triangle"></i> Eliminar Familia
            </h2>
            <p class="text-muted mb-0">
                ¿Estás seguro de que deseas eliminar esta familia? Esta acción no se puede deshacer.
            </p>
        </div>

        <!-- Detalle de la familia -->
        <div class="mb-4">
            <label asp-for="NombreFamilia" class="form-label fw-semibold">Nombre Familia</label>
            <input asp-for="NombreFamilia" class="form-control bg-white" disabled />
        </div>

        <!-- Botones de acción -->
        <div class="d-flex justify-content-center gap-3">
            <button type="submit" class="btn btn-danger px-4">
                <i class="bi bi-trash3-fill"></i> Borrar
            </button>
            <a asp-controller="Familia" asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left-circle"></i> Cancelar
            </a>
        </div>
    </form>
</div>
