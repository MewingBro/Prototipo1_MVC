@model List<Familia>
<partial name="_Notification" />

<div class="container mt-4">
    <div class="row align-items-center mb-3">
        <div class="col-md-6">
            <h2 class="text-primary mb-0">
                <i class="bi bi-diagram-3 me-2"></i>Lista de Familias de Productos
            </h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-controller="Familia" asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> Agregar Familia
            </a>
        </div>
    </div>

    <!-- 🔍 Filtro -->
    <form method="get" asp-action="Index" class="row g-2 align-items-end mb-4">
        <div class="col-md-4">
            <label class="form-label fw-bold">Buscar</label>
            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control shadow-sm" placeholder="Nombre de familia..." />
        </div>

        <div class="col-md-3 d-flex justify-content-end gap-2">
            <button type="submit" class="btn btn-warning shadow-sm w-100">
                <i class="bi bi-search"></i> Filtrar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm w-100">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        </div>
    </form>

    <!-- 📋 Tabla -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-bordered table-hover align-middle text-center">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Nombre de la Familia</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-3">
                            No se encontraron familias que coincidan con el filtro.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var obj in Model)
                    {
                        <tr>
                            <td>@obj.IdFamilia</td>
                            <td>@obj.NombreFamilia</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-controller="Familia" asp-action="Editar" asp-route-idfamilia="@obj.IdFamilia" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="Familia" asp-action="Borrar" asp-route-idfamilia="@obj.IdFamilia" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- 📄 Paginación -->
    @{
        int page = ViewBag.Page;
        int pageSize = ViewBag.PageSize;
        int total = ViewBag.TotalFamilias;
        int totalPages = (int)Math.Ceiling((double)total / pageSize);
    }

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center pagination-sm">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-searchString="@ViewBag.SearchString">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
