@model List<Familia>
<partial name="_Notification" />
    <div class="container">

    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">Lista de Familias de productos</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Familia" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Agregar Familia
            </a>
        </div>
    </div>


<table class="table table-bordered table-stripped">
    <thead>
    <tr>
        <th>
            Id de Familia
        </th>
        <th>
            Nombre de la Familia
        </th>
        <th>

        </th>
    </tr>
    </thead>
    <tbody>
        @foreach (var obj in Model.OrderBy(u=>u.IdFamilia))
        {
            <tr>
                <td>
                    @obj.IdFamilia
            </td>
            <td>
                    @obj.NombreFamilia
            </td>
            <td>
                <div class="w-75 btn-group" role="group">
                    <a asp-controller="Familia" asp-action="Editar" asp-route-idfamilia="@obj.IdFamilia" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil">Editar familia</i>
                    </a>
                            <a asp-controller="Familia" asp-action="Borrar" asp-route-idfamilia="@obj.IdFamilia" class="btn btn-danger mx-2">
                                <i class="bi bi-trash3"></i>Borrar familia
                            </a>
                            
                </div>
            </td>
        
        </tr>
        }
    </tbody>
</table>

</div>
