@model Prototipo1.Areas.Ingeniero.Controllers.UsuarioUpsertVM

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0 fw-semibold">
                <i class="bi bi-person-fill me-2"></i>
                @(Model.Id == null ? "Registrar Usuario" : "Editar Usuario")
            </h4>
        </div>

        <div class="card-body p-4">
            <form method="post" class="row g-3">
                <input type="hidden" asp-for="Id" />

                <!-- Correo -->
                <div class="col-12">
                    <div class="form-floating">
                        <input asp-for="Email" class="form-control" placeholder="Correo electrónico" />
                        <label asp-for="Email">Correo electrónico</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Contraseña y Confirmar Contraseña -->
                @if (Model != null)
                {
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Password" class="form-control" placeholder="Contraseña" type="password" />
                            <label asp-for="Password">Contraseña</label>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirmar contraseña" type="password" />
                            <label asp-for="ConfirmPassword">Confirmar contraseña</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>
                }

                <!-- Rol -->
                <div class="col-12">
                    <div class="form-floating">
                        <select asp-for="Role" asp-items="@Model.RoleList" class="form-select">
                            <option disabled selected>--Seleccionar Rol--</option>
                        </select>
                        <label asp-for="Role">Rol del usuario</label>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Botones -->
                <div class="col-12 mt-3">
                    <div class="row g-2">
                        <div class="col-12 col-md-6">
                            <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm">
                                <i class="bi bi-check-circle me-1"></i>
                                @(Model.Id == null ? "Registrar Usuario" : "Guardar Cambios")
                            </button>
                        </div>
                        <div class="col-12 col-md-6">
                            <a asp-area="Ingeniero" asp-controller="Usuarios" asp-action="Index"
                               class="btn btn-outline-secondary w-100 py-2 shadow-sm">
                                <i class="bi bi-arrow-left-circle me-1"></i> Volver
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
