@model Microsoft.AspNetCore.Identity.IdentityUser

<form method="post" class="row justify-content-center">
    <input asp-for="Id" hidden />

    <div class="col-12 col-md-8 col-lg-6">
        <div class="border p-4 mt-5 rounded-3 shadow-sm bg-light">
            <div class="text-center pb-3">
                <h2 class="text-danger fw-bold">
                    <i class="bi bi-person-x-fill me-2"></i> Borrar Usuario
                </h2>
                <p class="text-muted mb-0">Esta acción eliminará permanentemente la cuenta seleccionada.</p>
            </div>

            <hr class="my-3" />

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold">
                    <i class="bi bi-envelope-at-fill me-1"></i> Correo electrónico
                </label>
                <input asp-for="Email" disabled class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="bi bi-person-badge-fill me-1"></i> Nombre de usuario
                </label>
                <input value="@Model.UserName" disabled class="form-control" />
            </div>

            <div class="alert alert-warning mt-4 shadow-sm">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong>Advertencia:</strong> ¿Está seguro de que desea eliminar este usuario?
                <br>Esta acción <u>no se puede deshacer</u>.
            </div>

            <div class="row mt-4">
                <div class="col-12 col-md-6 mb-2 mb-md-0">
                    <button type="submit" class="btn btn-danger w-100 shadow-sm">
                        <i class="bi bi-trash3-fill me-1"></i> Borrar Usuario
                    </button>
                </div>
                <div class="col-12 col-md-6">
                    <a asp-area="Ingeniero" asp-controller="Usuarios" asp-action="Index"
                       class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left-circle me-1"></i> Volver a la lista
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

