@model UsuariosProyectos

<form asp-action="Borrar" method="post">
    <input asp-for="IdUsuario" hidden />
    <input asp-for="IdUsuariosProyectos" hidden />
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">
                Borrar acceso al usuario?
            </h2>
        </div>


        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">Borrar</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="UsuariosProyectos" asp-action="Index" asp-route-IdUsuario="@ViewBag.IdUsuario" class="btn btn-outline-secondary form-control">
                    Volver a la lista de accesos
                </a>
            </div>
        </div>
    </div>
</form>
