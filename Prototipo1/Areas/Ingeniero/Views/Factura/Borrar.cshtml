@model Factura

<form method="post">
    <input asp-for="IdFactura" hidden/>
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">
                Borrar Factura
            </h2>
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Fecha" class="p-0"></label>
            <input asp-for="Fecha" disabled class="form-control" />
        </div>

        <div class="mb-3 row p-1">
            <label asp-for="Comentario" class="p-0"></label>
            <input asp-for="Comentario" disabled class="form-control" />
        </div>


        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">Borrar</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Factura" asp-action="Index" class="btn btn-outline-secondary form-control">
                    Volver a la lista
                </a>
            </div>
        </div>
    </div>
</form>
