@model Prototipo1.Models.ViewModels.FacturaVM

<form method="post" class="row justify-content-center" enctype="multipart/form-data">
    <input asp-for="Factura.IdFactura" hidden />
    <input asp-for="Factura.IdProyecto" value="@Context.Session.GetInt32("IdProyecto")" hidden />

    <div class="col-lg-8 col-md-10 col-sm-12">
        <div class="card shadow-lg border-0 mt-4">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0 text-center fw-semibold">
                    @(Model.Factura.IdFactura != 0 ? "Actualizar Factura" : "Crear Factura")
                </h4>
            </div>

            <div class="card-body px-4 py-4">
                <div class="mb-3">
                    <label asp-for="Factura.Fecha" class="form-label fw-semibold"></label>
                    <input asp-for="Factura.Fecha" class="form-control" />
                    <span asp-validation-for="Factura.Fecha" class="text-danger"></span>
                </div>

                @if (ViewBag.Tipo == "Entrada")
                {
                    <input asp-for="Factura.IdTipoFactura" value="1" hidden />
                }
                else if (ViewBag.Tipo == "Salida")
                {
                    <input asp-for="Factura.IdTipoFactura" value="2" hidden />
                }

                <div class="mb-3">
                    <label asp-for="Factura.Comentario" class="form-label fw-semibold"></label>
                    <input asp-for="Factura.Comentario" class="form-control" />
                    <span asp-validation-for="Factura.Comentario" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Factura.RecibidoPor" class="form-label fw-semibold"></label>
                    <input asp-for="Factura.RecibidoPor" class="form-control" />
                    <span asp-validation-for="Factura.RecibidoPor" class="text-danger"></span>
                </div>

                @if (ViewBag.Tipo == "Salida")
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Recinto</label>
                        <select asp-for="@Model.Factura.IdRecinto" asp-items="@Model.RecintoList" class="form-select">
                            <option disabled selected>---Seleccionar Recinto---</option>
                        </select>
                        <span asp-validation-for="Factura.IdRecinto" class="text-danger"></span>
                    </div>
                }
                else
                {
                    <input asp-for="Factura.IdRecinto" value="" hidden />
                }

                <hr class="my-4" />

                <!-- Botones principales -->
                <div class="row g-3">
                    <div class="col-md-6">
                        @if (ViewBag.Tipo == "Entrada")
                        {
                            @if (Model.Factura.IdFactura != 0)
                            {
                                <a asp-controller="FacturaProducto" asp-action="Index" asp-route-IdFactura="@Model.Factura.IdFactura" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-plus-circle me-1"></i> Agregar Productos a la Factura
                                </a>
                            }
                            else
                            {
                                <button type="submit" name="accion" value="AgregarProductosAhora" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-save me-1"></i> Guardar y Agregar Productos
                                </button>
                            }
                        }
                        else if (ViewBag.Tipo == "Salida")
                        {
                            @if (Model.Factura.IdFactura != 0)
                            {
                                <a asp-controller="FacturaSalidaProducto"
                                   asp-action="Index"
                                   asp-route-IdFactura="@Model.Factura.IdFactura"
                                   asp-route-IdRecinto="@Model.Factura.IdRecinto"
                                   class="btn btn-outline-primary w-100">
                                    <i class="bi bi-plus-circle me-1"></i> Agregar Productos a la Factura
                                </a>
                            }
                            else
                            {
                                <button type="submit" name="accion" value="AgregarProductosAhora" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-save me-1"></i> Guardar y Agregar Productos
                                </button>
                            }
                        }
                    </div>

                    <div class="col-md-6">
                        @if (Model.Factura.IdFactura != 0)
                        {
                            <button type="submit" name="accion" value="AgregarProductosDespues" class="btn btn-success w-100">
                                <i class="bi bi-arrow-repeat me-1"></i> Actualizar Factura
                            </button>
                        }
                        else
                        {
                            <button type="submit" name="accion" value="AgregarProductosDespues" class="btn btn-success w-100">
                                <i class="bi bi-check-circle me-1"></i> Agregar Factura y volver al menú
                            </button>
                        }
                    </div>
                </div>

                <!-- Botón volver -->
                <div class="row mt-4">
                    <div class="col-md-6">
                        @if (ViewBag.Tipo == "Entrada")
                        {
                            <a asp-controller="Factura" asp-action="Index" asp-route-Tipo="Entrada" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-arrow-left-circle me-1"></i> Volver a la lista
                            </a>
                        }
                        else if (ViewBag.Tipo == "Salida")
                        {
                            <a asp-controller="Factura" asp-action="Index" asp-route-Tipo="Salida" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-arrow-left-circle me-1"></i> Volver a la lista
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
