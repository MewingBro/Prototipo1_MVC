@model Prototipo1.Models.ViewModels.FacturaCompletaSalidaVM
@{
    Layout = null;
    var factura = Model.Factura;
    var detalles = Model.Detalles;
    var fechaGeneracion = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Boleta de Salida - @factura.IdFactura</title>
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            margin: 20px 40px;
            color: #333;
            font-size: 14px;
        }

        .boleta {
            margin-bottom: 60px;
            page-break-after: always;
        }

        .encabezado {
            display: grid;
            grid-template-columns: 100px 1fr 200px;
            align-items: center;
            border: 1px solid #444;
            border-radius: 6px;
            padding: 10px 15px;
            margin-bottom: 20px;
        }

        .logo {
            text-align: center;
        }

            .logo img {
                max-width: 90px;
                height: auto;
            }

        .titulo {
            text-align: center;
        }

            .titulo h1 {
                font-size: 22px;
                margin: 0;
                color: #222;
            }

            .titulo p {
                margin: 0;
                font-size: 14px;
                color: #555;
            }

        .info-reporte {
            text-align: right;
            font-size: 13px;
            color: #666;
        }

        .info-factura {
            margin-bottom: 15px;
        }

            .info-factura table {
                width: 100%;
                border-collapse: collapse;
            }

            .info-factura th {
                text-align: left;
                padding: 4px;
                width: 180px;
            }

            .info-factura td {
                padding: 4px;
            }

        .detalle-factura table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            font-size: 13px;
        }

        .detalle-factura th, .detalle-factura td {
            border: 1px solid #ccc;
            padding: 6px;
            text-align: center;
        }

        .detalle-factura th {
            background-color: #f5f5f5;
        }

        .firma {
            margin-top: 40px;
            display: flex;
            justify-content: space-between;
        }

            .firma .campo {
                width: 45%;
                text-align: center;
                padding-top: 40px;
                border-top: 1px solid #000;
                font-size: 13px;
            }

        .footer {
            margin-top: 25px;
            text-align: center;
            font-size: 11px;
            color: #777;
        }

        .btn-imprimir {
            display: block;
            margin: 25px auto;
            padding: 10px 25px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
        }

        .media print {
            .btn-imprimir

        {
            display: none;
        }

        body {
            margin: 0;
        }

        }
    </style>
</head>
<body>

    @for (int copia = 0; copia < 2; copia++)
    {
        <div class="boleta">
            <!-- Encabezado -->
            <div class="encabezado">
                <div class="logo">
                    <img src="/images/logo.png" alt="Logo Empresa" />
                </div>
                <div class="titulo">
                    <h1>Boleta de Solicitud de Materiales de la Obra</h1>
                    <p>Sistema de Gestión</p>
                </div>
                <div class="info-reporte">
                    <p><strong>Fecha de generación:</strong><br />@fechaGeneracion</p>
                    <p><strong>Copia:</strong> @(copia == 0 ? "Original" : "Cliente")</p>
                </div>
            </div>

            <!-- Información general -->
            <div class="info-factura">
                <table>
                    <tr>
                        <th>Proyecto:</th>
                        <td>@factura.Proyecto?.NombreProyecto</td>
                    </tr>
                    <tr>
                        <th>Recinto:</th>
                        <td>@factura.Recinto?.NombreRecinto</td>
                    </tr>
                    <tr>
                        <th>Nivel:</th>
                        <td>@factura.Recinto?.Aposento?.Nivel?.NombreNivel</td>
                    </tr>
                    <tr>
                        <th>Aposento:</th>
                        <td>@factura.Recinto?.Aposento?.NombreAposento</td>
                    </tr>
                    <tr>
                        <th>N° de Boleta:</th>
                        <td>@factura.IdFactura</td>
                    </tr>
                    <tr>
                        <th>Fecha de Solicitud:</th>
                        <td>@factura.Fecha.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <th>Comentario:</th>
                        <td>@factura.Comentario</td>
                    </tr>
                </table>
            </div>

            <!-- Detalles -->
            <div class="detalle-factura">
                <h4>Materiales Solicitados</h4>
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Código</th>
                            <th>Nombre</th>
                            <th>Unidad</th>
                            <th>Cantidad Solicitada</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (detalles != null && detalles.Any())
                        {
                            var index = 1;
                            foreach (var item in detalles)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@item.Producto?.CodigoProducto</td>
                                    <td>@item.Producto?.NombreProducto</td>
                                    <td>@item.Producto?.Unidad?.NombreUnidad</td>
                                    <td>@item.CantidadDisminuida</td>
                                </tr>
                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5">No hay materiales solicitados en esta boleta.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Firma -->
            <div class="firma">
                <div class="campo">
                    Solicitado por: <strong>@factura.RecibidoPor</strong>
                </div>
                <div class="campo">
                    Firma y Sello
                </div>
            </div>

            <div class="footer">
                <p>Boleta generada automáticamente por el sistema — @fechaGeneracion</p>
            </div>
        </div>
    }

    <button class="btn-imprimir" onclick="window.print()">🖨️ Imprimir Boleta</button>
</body>
</html>
