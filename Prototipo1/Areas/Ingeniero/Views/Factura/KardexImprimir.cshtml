@model Prototipo1.Models.ViewModels.KardexVM
@{
    Layout = null;
    var fechaGeneracion = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Reporte Kardex - @Model.Producto?.NombreProducto</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            margin: 40px;
            color: #000;
        }

        .logo {
            max-height: 70px;
        }

        .titulo {
            text-align: center;
            margin-bottom: 20px;
        }

        .info-producto {
            font-size: 14px;
        }

        table {
            font-size: 13px;
        }
        .media print {
            .no-print

        {
            display: none;
        }

        body {
            margin: 20px;
        }

        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <!-- Encabezado -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <img src="~/Images/logo.png" class="logo" alt="Logo Empresa" />
            </div>
            <div class="text-end">
                <h5 class="mb-0">Reporte Kardex</h5>
                <small>Fecha de generación: @fechaGeneracion</small><br />
                <small>Proyecto: @ViewBag.Proyecto</small>
            </div>
        </div>

        <!-- Título -->
        <h4 class="titulo text-primary">Kardex de Producto</h4>

        <!-- Información del producto -->
        <div class="info-producto mb-4 border rounded p-3 bg-light">
            <strong>Producto:</strong> @Model.Producto?.NombreProducto <br />
            <strong>Código:</strong> @Model.Producto?.CodigoProducto <br />
            <strong>Familia:</strong> @Model.Producto?.Familia?.NombreFamilia <br />
            <strong>Unidad:</strong> @Model.Producto?.Unidad?.NombreUnidad <br />
            <strong>Media:</strong> @Model.Producto?.MediaAritmetica <br />
            <strong>Descripción:</strong> @Model.Producto?.Descripcion
        </div>

        <!-- Tabla de movimientos -->
        <table class="table table-bordered text-center align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Fecha</th>
                    <th>ID Factura</th>
                    <th>Tipo</th>
                    <th>Entrada</th>
                    <th>Salida</th>
                    <th>Saldo</th>
                    <th>Nivel</th>
                    <th>Aposento</th>
                    <th>Recinto</th>
                    <th>Comentario</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mov in Model.Movimientos)
                {
                    <tr>
                        <td>@mov.FechaFactura.ToShortDateString()</td>
                        <td>@mov.IdFactura</td>
                        <td>@mov.TipoFactura</td>
                        <td>@(mov.CantidadAumentada == 0 ? "-" : mov.CantidadAumentada.ToString())</td>
                        <td>@(mov.CantidadDisminuida == 0 ? "-" : mov.CantidadDisminuida.ToString())</td>
                        <td><strong>@mov.Saldo</strong></td>
                        <td>@mov.Nivel</td>
                        <td>@mov.Aposento</td>
                        <td>@mov.Recinto</td>
                        <td class="text-start">@mov.Comentario</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Botón para imprimir -->
        <div class="text-center mt-4 no-print">
            <button class="btn btn-primary" onclick="window.print()">
                <i class="bi bi-printer"></i> Imprimir
            </button>
            <a asp-action="Kardex" class="btn btn-outline-secondary">
                Volver
            </a>
        </div>
    </div>
</body>
</html>
