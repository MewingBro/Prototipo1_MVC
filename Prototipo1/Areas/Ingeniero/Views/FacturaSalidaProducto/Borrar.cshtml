@model FacturaSalidaProducto

<div class="container py-4">
    <form asp-action="Borrar" method="post" class="shadow-sm border rounded p-4 bg-light">
        <input asp-for="IdFactura" type="hidden" />
        <input asp-for="IdFacturaSalidaProducto" type="hidden" />

        <!-- Encabezado -->
        <div class="mb-4 text-center">
            <h2 class="text-danger fw-bold">
                <i class="bi bi-trash3"></i> Confirmar Eliminación
            </h2>
            <p class="text-muted mb-0">
                ¿Estás seguro de que deseas eliminar este detalle de salida de factura?
            </p>
        </div>

        <!-- Información del detalle -->
        <div class="mb-3">
            <label asp-for="CantidadDisminuida" class="form-label fw-semibold">Cantidad Disminuida</label>
            <input asp-for="CantidadDisminuida" class="form-control bg-white" disabled />
        </div>

        <div class="mb-4">
            <label asp-for="EntregadoA" class="form-label fw-semibold">Entregado A</label>
            <input asp-for="EntregadoA" class="form-control bg-white" disabled />
        </div>

        <!-- Botones -->
        <div class="d-flex justify-content-center gap-3">
            <button type="submit" class="btn btn-danger px-4">
                <i class="bi bi-trash-fill"></i> Borrar
            </button>
            <a asp-controller="FacturaSalidaProducto"
               asp-action="Index"
               asp-route-IdFactura="@ViewBag.IdFactura"
               class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left-circle"></i> Cancelar
            </a>
        </div>
    </form>
</div>
