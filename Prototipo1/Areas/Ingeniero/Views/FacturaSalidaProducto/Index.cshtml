@model List<FacturaSalidaProducto>
<partial name="_Notification" />

<div class="container">

    <!-- Título -->
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">Productos Despachados</h2>
        </div>

        <div class="col-6 text-end">
            <a asp-controller="FacturaSalidaProducto"
               asp-action="Upsert"
               asp-route-IdFactura="@ViewBag.IdFactura"
               class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Agregar Producto
            </a>
        </div>
    </div>

    <!-- Filtros -->
    <div class="row mb-4">
        <form method="get" asp-action="Index" class="row g-2">
            <input type="hidden" name="IdFactura" value="@ViewBag.IdFactura" />

            <div class="col-12 col-md">
                <input type="text" name="Producto" value="@ViewBag.Producto" placeholder="Producto" class="form-control w-100" />
            </div>

            <div class="col-12 col-md">
                <input type="text" name="EntregadoA" value="@ViewBag.EntregadoA" placeholder="Entregado a" class="form-control w-100" />
            </div>

            <div class="col-12 col-md">
                <input type="text" name="Familia" value="@ViewBag.Familia" placeholder="Familia" class="form-control w-100" />
            </div>

            <div class="col-12 col-md">
                <input type="text" name="Unidad" value="@ViewBag.Unidad" placeholder="Unidad" class="form-control w-100" />
            </div>

            <!-- Botones -->
            <div class="col-12 col-md-auto d-flex gap-2">
                <button type="submit" class="btn btn-warning text-white w-100">Filtrar</button>
                <a asp-action="Index" asp-route-IdFactura="@ViewBag.IdFactura" class="btn btn-outline-secondary w-100">Limpiar</a>
            </div>
        </form>
    </div>

    <!-- Tabla -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-bordered table-hover align-middle text-center">
            <thead class="table-primary">
                <tr>
                    <th>ID Factura</th>
                    <th>Producto</th>
                    <th>Familia</th>
                    <th>Unidad</th>
                    <th>Cantidad Disminuida</th>
                    <th>Entregado A</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-3">No existen productos despachados en esta factura.</td>
                    </tr>
                }
                else
                {
                    foreach (var obj in Model)
                    {
                        <tr>
                            <td>@obj.IdFactura</td>
                            <td>@obj.Producto.NombreProducto</td>
                            <td>@obj.Producto.Familia?.NombreFamilia</td>
                            <td>@obj.Producto.Unidad?.NombreUnidad</td>
                            <td>@obj.CantidadDisminuida</td>
                            <td>@obj.EntregadoA</td>
                            <td>
                                <div class="btn-group w-100" role="group">
                                    <a asp-controller="FacturaSalidaProducto"
                                       asp-action="Upsert"
                                       asp-route-IdFactura="@ViewBag.IdFactura"
                                       asp-route-IdFacturaSalidaProducto="@obj.IdFacturaSalidaProducto"
                                       class="btn btn-primary btn-sm">Editar</a>

                                    <a asp-controller="FacturaSalidaProducto"
                                       asp-action="Borrar"
                                       asp-route-IdFactura="@ViewBag.IdFactura"
                                       asp-route-IdFacturaSalidaProducto="@obj.IdFacturaSalidaProducto"
                                       class="btn btn-danger btn-sm">Borrar</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Botón terminar factura -->
    <div class="mt-4">
        <form asp-controller="FacturaSalidaProducto"
              asp-action="TerminarFactura"
              asp-route-IdFactura="@ViewBag.IdFactura"
              method="post"
              style="display:inline;">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> Terminar despacho y disminuir productos al inventario
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (ViewBag.SinPresupuesto == true)
    {
        <script>
            Swal.fire({
                icon: 'warning',
                title: 'Sin productos presupuestados',
                text: 'El presupuesto de este recinto no se encuentra confirmado',
                confirmButtonText: 'Volver al listado de facturas',
                confirmButtonColor: '#0dcaf0' // 💙 Celeste (Bootstrap info)
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("Index", "Factura", new { Tipo = "Salida" })';
                }
            });
        </script>
    }

    @if (TempData["AlertaInventario"] != null)
    {
        <script>
            Swal.fire({
                icon: 'warning',
                title: 'Advertencia de Inventario',
                html: '@Html.Raw(TempData["AlertaInventario"])',
                confirmButtonColor: '#f0ad4e',
                confirmButtonText: 'Entendido'
            });
        </script>
    }

    @if (TempData["AlertaPresupuesto"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong>@TempData["AlertaPresupuesto"]</strong>
            <div class="mt-2">
                <form asp-controller="Cambio" asp-action="Create" method="post">
                    <input type="hidden" name="IdFactura" value="@ViewBag.IdFactura" />
                    <button type="submit" class="btn btn-primary btn-sm">
                        Iniciar Solicitud de Cambio
                    </button>
                </form>

                <a asp-controller="Factura"
                   asp-action="Index"
                   asp-route-Tipo="Salida"
                   class="btn btn-secondary btn-sm">
                    Volver a Facturas
                </a>
            </div>

            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
}

