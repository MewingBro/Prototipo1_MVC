@model Inventario
<partial name="_Notification" />

<div class="container mt-4">
    <div class="row">
        <div class="col-12 col-md-8 offset-md-2">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        @(Model.IdInventario == 0 ? "Agregar Inventario" : "Editar Inventario")
                    </h4>
                </div>

                <div class="card-body">
                    <form method="post" asp-action="Upsert" class="needs-validation" novalidate>
                        <input type="hidden" asp-for="IdInventario" />
                        <input type="hidden" asp-for="IdProyecto" />
                        <input type="hidden" asp-for="IdProducto" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Código del Producto</label>
                            <input type="text" class="form-control" value="@Model.Producto?.CodigoProducto" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nombre del Producto</label>
                            <input type="text" class="form-control" value="@Model.Producto?.NombreProducto" readonly />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Familia</label>
                                <input type="text" class="form-control" value="@Model.Producto?.Familia?.NombreFamilia" readonly />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Unidad</label>
                                <input type="text" class="form-control" value="@Model.Producto?.Unidad?.NombreUnidad" readonly />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Existencias" class="form-label fw-semibold">Existencias</label>
                            <input asp-for="Existencias" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Existencias" class="text-danger"></span>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Guardar
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left-circle"></i> Volver
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
