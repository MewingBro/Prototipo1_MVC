@model List<Inventario>

@{
    Layout = null; // Sin layout para que sea más limpio al imprimir
    var fecha = DateTime.Now.ToString("dd/MM/yyyy");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Reporte de Inventario</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            font-size: 13px;
            color: #333;
            margin: 20px;
        }

        .header {
            border-bottom: 2px solid #0d6efd;
            margin-bottom: 20px;
            padding-bottom: 10px;
        }

            .header img {
                height: 60px;
            }

            .header h2 {
                color: #0d6efd;
                margin-left: 10px;
            }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 6px;
            text-align: center;
        }

        th {
            background-color: #f2f6ff;
            color: #0d6efd;
            font-weight: 600;
        }

        .footer {
            position: fixed;
            bottom: 10px;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 11px;
            color: #888;
        }

        .media print {
            .btn-print

        {
            display: none;
        }

        }
    </style>
</head>
<body>
    <div class="header d-flex align-items-center">
        <img src="~/Images/logo.png" alt="Logo" class="me-2" />
        <div>
            <h2 class="mb-0">Reporte de Inventario</h2>
            <small>Fecha de generación: @fecha</small>
        </div>
    </div>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID Inventario</th>
                <th>ID Producto</th>
                <th>Nombre del Producto</th>
                <th>Familia</th>
                <th>Unidad</th>
                <th>Proyecto</th>
                <th>Existencias</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderBy(i => i.IdInventario))
            {
                <tr>
                    <td>@item.IdInventario</td>
                    <td>@item.IdProducto</td>
                    <td>@item.Producto.NombreProducto</td>
                    <td>@item.Producto.Familia.NombreFamilia</td>
                    <td>@item.Producto.Unidad.NombreUnidad</td>
                    <td>@item.Proyecto.NombreProyecto</td>
                    <td>@item.Existencias</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end mt-4">
        <button class="btn btn-primary btn-print" onclick="window.print()">
            <i class="bi bi-printer"></i> Imprimir Reporte
        </button>
    </div>

    <div class="footer">
        <p>© @DateTime.Now.Year - Reporte generado automáticamente por el sistema de inventario.</p>
    </div>
</body>
</html>
