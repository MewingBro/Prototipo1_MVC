@model List<RecintoProducto>
<partial name="_Notification" />
<div class="container">

    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">Presupuesto del Recinto</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="RecintoProducto" asp-action="Upsert" asp-route-IdRecinto="@ViewBag.IdRecinto" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Agregar Producto
            </a>
        </div>
    </div>


    <table class="table table-bordered table-stripped">
        <thead>
            <tr>
                <th>
                    Id Aposento + Recinto
                </th>
                <th>
                    Id de Recinto
                </th>
                <th>
                    Nombre del Recinto
                </th>
                <th>
                    Id de Producto
                </th>
                <th>
                    Nombre del Producto
                </th>
                <th>
                    Presupuesto
                </th>
                <th>
                    Desperdicio
                </th>
                <th>
                    Existencias Actuales
                </th>
                <th>

                </th>

            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model.OrderBy(u => u.IdRecintoProducto))
            {

                <tr>
                    <td>
                        @obj.IdRecintoProducto
                    </td>
                    <td>
                        @obj.IdRecinto
                    </td>
                    <td>
                        @obj.Recinto.NombreRecinto
                    </td>
                    <td>
                        @obj.IdProducto
                    </td>
                    <td>
                        @obj.Producto.NombreProducto
                    </td>
                    <td>
                        @obj.Presupuesto
                    </td>
                    <td>
                        @obj.Desperdicio
                    </td>
                    <td>
                        @obj.ExistenciasActuales
                    </td>

                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="RecintoProducto" asp-action="Upsert" asp-route-IdRecinto="@ViewBag.IdRecinto" asp-route-IdRecintoProducto="@obj.IdRecintoProducto" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil">Editar presupuesto</i>
                            </a>
                            <a asp-controller="RecintoProducto" asp-action="Borrar" asp-route-IdRecinto="@ViewBag.IdRecinto" asp-route-IdRecintoProducto="@obj.IdRecintoProducto" class="btn btn-danger mx-2">
                                <i class="bi bi-trash3">Borrar presupuesto</i>
                            </a>

                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>

    <div class="col-6">
        <form asp-controller="RecintoProducto" asp-action="ConfirmarPresupuesto" asp-route-IdRecinto="@ViewBag.IdRecinto" method="post" style="display:inline;">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Confirmar presupuesto
            </button>
        </form>
    </div>

</div>
