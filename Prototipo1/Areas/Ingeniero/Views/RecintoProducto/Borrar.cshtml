@model RecintoProducto

<form asp-action="Borrar" method="post">
    <input asp-for="IdRecinto" hidden />
    <input asp-for="IdRecintoProducto" hidden />
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">
                Borrar Detalle
            </h2>
        </div>

        <div class="mb-3 row p-1">
            <label asp-for="Presupuesto" class="p-0"></label>
            <input asp-for="Presupuesto" disabled class="form-control" />
        </div>

        <div class="mb-3 row p-1">
            <label asp-for="Desperdicio" class="p-0"></label>
            <input asp-for="Desperdicio" disabled class=" form-control" />
        </div>

        <div class="mb-3 row p-1">
            <label asp-for="ExistenciasActuales" class="p-0"></label>
            <input asp-for="ExistenciasActuales" disabled class=" form-control" />
        </div>


        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">Borrar</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="RecintoProducto" asp-action="Index" asp-route-IdRecinto="@ViewBag.IdRecinto" class="btn btn-outline-secondary form-control">
                    Volver a la lista de presupuestos
                </a>
            </div>
        </div>
    </div>
</form>
