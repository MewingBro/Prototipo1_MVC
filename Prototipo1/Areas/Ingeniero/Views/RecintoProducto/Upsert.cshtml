@model Prototipo1.Models.ViewModels.FacturaProductoVM

<form asp-action="Upsert" asp-controller="FacturaProducto" method="post" class="row" enctype="multipart/form-data">

    <input asp-for="FacturaProducto.IdFactura" value="@ViewBag.IdFactura" hidden />
    <input asp-for="FacturaProducto.IdFacturaProducto" hidden />
    <div class="row">
        <div class="col-10">
            <div class="border p-3 mt-4">
                <div class="row pb-2">
                    <h2 class="text-primary">
                        @(Model.FacturaProducto.IdFacturaProducto != 0 ? "Actualizar" : "Crear") Detalle
                    </h2>
                </div>

                <div class="mb-3 row p-1">
                    <label class="p-0">Producto</label>
                    <select asp-for="@Model.FacturaProducto.IdProducto" asp-items="@Model.ProductoList" class="form-select">
                        <option disabled selected>---Seleccionar Producto---</option>
                    </select>
                    <span asp-validation-for="FacturaProducto.IdProducto" class="text-danger"></span>
                </div>

                <div class="mb-3 row p-1">
                    <label asp-for="FacturaProducto.CantidadAumentada" class="p-0"></label>
                    <input asp-for="FacturaProducto.CantidadAumentada" class="form-control" />
                    <span asp-validation-for="FacturaProducto.CantidadAumentada" class="text-danger"></span>
                </div>

                <div class="mb-3 row p-1">
                    <label asp-for="FacturaProducto.EntregadoA" class="p-0"></label>
                    <input asp-for="FacturaProducto.EntregadoA" class="form-control" />
                    <span asp-validation-for="FacturaProducto.EntregadoA" class="text-danger"></span>
                </div>


                <div class="row">
                    <div class="col-6 col-md-3">
                        @if (Model.FacturaProducto.IdFacturaProducto != 0)
                        {
                            <button type="submit" class="btn btn-primary form-control">Actualizar</button>
                            
                        } else
                        {
                            <button type="submit" class="btn btn-primary form-control">Agregar</button>
                        }

                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-controller="FacturaProducto" asp-action="Index" asp-route-IdFactura="@ViewBag.IdFactura" class="btn btn-outline-secondary form-control">
                            Volver a la lista de Productos
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>

</form>
