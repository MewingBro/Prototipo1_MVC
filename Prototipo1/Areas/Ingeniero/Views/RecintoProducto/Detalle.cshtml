@model List<RecintoProducto>
<partial name="_Notification" />

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-md-6">
            <h2 class="text-primary">Detalle de Presupuesto por Recinto</h2>
        </div>
    </div>

    <!-- 🔍 FILTROS -->
    <form asp-action="Detalle" method="get" class="row mb-3">
        <div class="col-md-3 mb-2">
            <input type="text" name="nombreNivel" value="@ViewBag.NombreNivel" class="form-control" placeholder="Buscar por nivel" />
        </div>

        <div class="col-md-3 mb-2">
            <input type="text" name="nombreAposento" value="@ViewBag.NombreAposento" class="form-control" placeholder="Buscar por aposento" />
        </div>

        <div class="col-md-3 mb-2">
            <input type="text" name="nombreRecinto" value="@ViewBag.NombreRecinto" class="form-control" placeholder="Buscar por recinto" />
        </div>

        <div class="col-md-3 mb-2">
            <input type="text" name="nombreProducto" value="@ViewBag.NombreProducto" class="form-control" placeholder="Buscar por producto" />
        </div>

        <div class="col-md-3 mb-2">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="SoloCero" id="SoloCero" value="true" @(ViewBag.SoloCero == true ? "checked" : "") />
                <label class="form-check-label" for="SoloCero">
                    Mostrar solo existencias en 0
                </label>
            </div>
        </div>

        <!-- Filtro Estado -->
        <div class="col-12 col-md">
            <select name="Estado" class="form-select w-100">
                <option value="">Todos los estados</option>
                <option value="Pendiente" selected="@(ViewBag.Estado == "Pendiente" ? "selected" : null)">Pendiente</option>
                <option value="Confirmado" selected="@(ViewBag.Estado == "Confirmado" ? "selected" : null)">Confirmado</option>
            </select>
        </div>

        <div class="col-md-3 mb-2 d-flex gap-2">
            <button type="submit" class="btn btn-info">Filtrar</button>
            <a asp-action="Detalle" class="btn btn-outline-secondary w-50">Limpiar</a>
        </div>
    </form>

    <!-- 🔢 TABLA -->
    <table class="table table-bordered table-striped align-middle text-center">
        <thead class="table-primary">
            <tr>
                <th>Nivel</th>
                <th>Aposento</th>
                <th>Recinto</th>
                <th>Producto</th>
                <th>Presupuesto</th>
                <th>Desperdicio</th>
                <th>Existencias Actuales</th>
                <th>Estado Presupuesto</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-muted text-center py-3">
                        No hay registros que coincidan con los filtros.
                    </td>
                </tr>
            }
            else
            {
                foreach (var obj in Model)
                {
                    <tr>
                        <td>@obj.Recinto.Aposento.Nivel.NombreNivel</td>
                        <td>@obj.Recinto.Aposento.NombreAposento</td>
                        <td>@obj.Recinto.NombreRecinto</td>
                        <td>@obj.Producto.NombreProducto</td>
                        <td>@obj.Presupuesto</td>
                        <td>@obj.Desperdicio</td>
                        <td>@obj.ExistenciasActuales</td>
                        @if (obj.Recinto.EstadoRecinto == 0)
                        {
                            <td>Pendiente</td>

                        } else if (obj.Recinto.EstadoRecinto == 1)
                        {
                            <td>Confirmado</td>
                        }
                    </tr>
                }
            }
        </tbody>
    </table>

    <!-- 📄 PAGINACIÓN -->
    @{
        int page = ViewBag.Page;
        int totalPages = ViewBag.TotalPages;
    }
    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Detalle"
                           asp-route-nombreNivel="@ViewBag.NombreNivel"
                           asp-route-nombreAposento="@ViewBag.NombreAposento"
                           asp-route-nombreRecinto="@ViewBag.NombreRecinto"
                           asp-route-nombreProducto="@ViewBag.NombreProducto"
                           asp-route-SoloCero="@ViewBag.SoloCero"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<div class="col-md-6">
    <a asp-action="Reporte"
       asp-route-nombreNivel="@ViewBag.NombreNivel"
       asp-route-nombreAposento="@ViewBag.NombreAposento"
       asp-route-nombreRecinto="@ViewBag.NombreRecinto"
       asp-route-nombreProducto="@ViewBag.NombreProducto"
       asp-route-SoloCero="@ViewBag.SoloCero"
       asp-route-Estado="@ViewBag.Estado"
       class="btn btn-outline-primary">
        <i class="bi bi-printer"></i> Imprimir Reporte
    </a>
</div>
