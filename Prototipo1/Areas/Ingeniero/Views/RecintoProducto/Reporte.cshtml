@model List<RecintoProducto>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    Layout = null;
    var horaGeneracion = DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss");
    string nombreProyecto = ViewBag.Proyecto ?? "Proyecto Desconocido";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Reporte de Presupuesto por Recinto</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            overflow-x: hidden;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
        }

        .container-fluid {
            width: 100%;
            padding: 10px 20px;
        }

        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 2px solid #0d6efd;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .header-left {
            display: flex;
            align-items: center;
        }

            .header-left img {
                height: 60px;
                margin-right: 15px;
            }

            .header-left .title {
                font-size: 1.8rem;
                font-weight: bold;
                color: #0d6efd;
            }

            .header-left .project {
                font-size: 1rem;
                color: #555;
            }

        .generation-time {
            font-size: 0.9rem;
            color: #555;
        }

        .no-print {
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 8px 12px;
            vertical-align: middle;
        }

        th {
            background-color: #0d6efd;
            color: white;
            text-align: center;
        }

        tbody tr:nth-child(even) {
            background-color: #f2f2f2;
        }

        .media print {
            .no-print

        {
            display: none;
        }

        body {
            margin: 5mm;
        }

        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <!-- Encabezado -->
        <div class="header">
            <div class="header-left">
                <img src="~/Images/logo.png" alt="Logo" />
                <div>
                    <div class="title">Reporte de Presupuesto por Recinto</div>
                    <div class="project">Proyecto: @nombreProyecto</div>
                </div>
            </div>
            <div class="generation-time no-print">
                Generado el: @horaGeneracion
            </div>
        </div>

        <!-- Botón imprimir -->
        <div class="no-print">
            <button class="btn btn-primary" onclick="window.print();">
                <i class="bi bi-printer"></i> Imprimir
            </button>
        </div>

        <!-- Tabla de datos -->
        <table class="table table-bordered table-striped text-center">
            <thead>
                <tr>
                    <th>Nivel</th>
                    <th>Aposento</th>
                    <th>Recinto</th>
                    <th>Producto</th>
                    <th>Presupuesto</th>
                    <th>Desperdicio</th>
                    <th>Existencias Actuales</th>
                    <th>Estado Presupuesto</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-muted text-center py-3">
                            No hay registros que coincidan con los filtros.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var obj in Model)
                    {
                        <tr>
                            <td>@obj.Recinto.Aposento.Nivel.NombreNivel</td>
                            <td>@obj.Recinto.Aposento.NombreAposento</td>
                            <td>@obj.Recinto.NombreRecinto</td>
                            <td>@obj.Producto.NombreProducto</td>
                            <td>@obj.Presupuesto</td>
                            <td>@obj.Desperdicio</td>
                            <td>@obj.ExistenciasActuales</td>
                            <td>@(obj.Recinto.EstadoRecinto == 0 ? "Pendiente" : "Confirmado")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</body>
</html>
