@model Prototipo1.Models.ViewModels.AposentoVM

<form method="post" class="row justify-content-center" enctype="multipart/form-data">
    <input asp-for="Aposento.IdAposento" hidden />

    <div class="col-lg-6 col-md-8 col-sm-12">
        <div class="card shadow-lg border-0 mt-5">
            <div class="card-header bg-primary text-white text-center py-3 rounded-top">
                <h4 class="mb-0 fw-semibold">
                    @(Model.Aposento.IdAposento != 0 ? "Actualizar Aposento" : "Crear Nuevo Aposento")
                </h4>
            </div>

            <div class="card-body px-4 py-4">
                <div class="mb-3">
                    <label asp-for="Aposento.NombreAposento" class="form-label fw-semibold"></label>
                    <input asp-for="Aposento.NombreAposento" class="form-control" placeholder="Ej. Aposento Principal" />
                    <span asp-validation-for="Aposento.NombreAposento" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label for="nivel" class="form-label fw-semibold">Nivel</label>
                    <select asp-for="Aposento.IdNivel" asp-items="@Model.NivelList" class="form-select">
                        <option disabled selected>--- Seleccionar Nivel ---</option>
                    </select>
                    <span asp-validation-for="Aposento.IdNivel" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-center gap-3 mt-4">
                    @if (Model.Aposento.IdAposento != 0)
                    {
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save-fill me-1"></i> Actualizar
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-plus-circle me-1"></i> Agregar
                        </button>
                    }

                    <a asp-controller="Aposento" asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left-circle me-1"></i> Volver a la lista
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>
