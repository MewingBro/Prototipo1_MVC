@model List<Aposento>
<partial name="_Notification" />
    <div class="container">

    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">Lista de Aposentos</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Aposento" asp-action="Upsert" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Agregar Aposento
            </a>
        </div>
    </div>


<table class="table table-bordered table-stripped">
    <thead>
    <tr>
        <th>
            Id de Aposento
        </th>
        <th>
            Nombre del Aposento
        </th>
                <th>
                    Nombre del Nivel
                </th>

                <th>
                    Nombre del Proyecto
                </th>
                <th>

                </th>
    </tr>
    </thead>
    <tbody>
        @foreach (var obj in Model.OrderBy(u=>u.IdAposento))
        {
            <tr>
            <td>
                @obj.IdAposento
            </td>
            <td>
                @obj.NombreAposento
            </td>
                    <td>
                        @obj.Nivel.NombreNivel
                    </td>
                    <td>
                        @obj.Nivel.Proyecto.NombreProyecto
                    </td>

            <td>
                <div class="w-75 btn-group" role="group">
                    <a asp-controller="Aposento" asp-action="Upsert" asp-route-IdAposento="@obj.IdAposento" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil">Editar Aposento</i>
                    </a>
                            <a asp-controller="Aposento" asp-action="Borrar" asp-route-IdAposento="@obj.IdAposento" class="btn btn-danger mx-2">
                                <i class="bi bi-trash3"></i>Borrar Aposento
                            </a>
                            
                </div>
            </td>
        
        </tr>
        }
    </tbody>
</table>

</div>
