@model List<Aposento>
<partial name="_Notification" />

<div class="container mt-4">
    <div class="row align-items-center mb-3">
        <div class="col-md-6">
            <h2 class="text-primary mb-0">
                <i class="bi bi-house-door me-2"></i>Lista de Aposentos
            </h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-controller="Aposento" asp-action="Upsert" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> Agregar Aposento
            </a>
        </div>
    </div>

    <!-- 🔍 Filtros -->
    <form method="get" asp-action="Index" class="row g-3 align-items-end mb-4">
        <div class="col-md-4">
            <label class="form-label fw-bold">Buscar por Aposento</label>
            <input type="text" name="searchAposento" value="@ViewBag.SearchAposento" class="form-control shadow-sm" placeholder="Nombre del aposento..." />
        </div>

        <div class="col-md-4">
            <label class="form-label fw-bold">Buscar por Nivel</label>
            <input type="text" name="searchNivel" value="@ViewBag.SearchNivel" class="form-control shadow-sm" placeholder="Nombre del nivel..." />
        </div>

        <div class="col-md-4 d-flex justify-content-end gap-2">
            <button type="submit" class="btn btn-warning shadow-sm w-50">
                <i class="bi bi-search"></i> Filtrar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm w-50">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        </div>
    </form>

    <!-- 📋 Tabla -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-bordered table-hover align-middle text-center">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Nombre del Aposento</th>
                    <th>Nivel</th>
                    <th>Proyecto</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-3">
                            No se encontraron aposentos que coincidan con los filtros.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var obj in Model)
                    {
                        <tr>
                            <td>@obj.IdAposento</td>
                            <td>@obj.NombreAposento</td>
                            <td>@obj.Nivel.NombreNivel</td>
                            <td>@obj.Nivel.Proyecto.NombreProyecto</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-controller="Aposento" asp-action="Upsert" asp-route-IdAposento="@obj.IdAposento" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="Aposento" asp-action="Borrar" asp-route-IdAposento="@obj.IdAposento" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- 📄 Paginación -->
    @{
        int page = ViewBag.Page;
        int pageSize = ViewBag.PageSize;
        int total = ViewBag.TotalAposentos;
        int totalPages = (int)Math.Ceiling((double)total / pageSize);
    }

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center pagination-sm">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-searchAposento="@ViewBag.SearchAposento"
                           asp-route-searchNivel="@ViewBag.SearchNivel">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
