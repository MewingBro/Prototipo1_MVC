@model Aposento

<form method="post" class="row justify-content-center">
    <input asp-for="IdAposento" hidden />

    <div class="col-lg-6 col-md-8 col-sm-12">
        <div class="card shadow-lg border-0 mt-5">
            <div class="card-header bg-danger text-white text-center py-3 rounded-top">
                <h4 class="mb-0 fw-semibold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Confirmar eliminación de Aposento
                </h4>
            </div>

            <div class="card-body px-4 py-4">
                <p class="text-center text-muted mb-4">
                    ¿Estás seguro de que deseas eliminar este aposento? <br />
                    Esta acción no se puede deshacer.
                </p>

                <div class="mb-4">
                    <label asp-for="NombreAposento" class="form-label fw-semibold">Nombre Aposento</label>
                    <input asp-for="NombreAposento" disabled class="form-control text-center fw-bold bg-light" />
                </div>

                <div class="d-flex justify-content-center gap-3 mt-4">
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash-fill me-1"></i> Borrar
                    </button>

                    <a asp-controller="Aposento" asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>
