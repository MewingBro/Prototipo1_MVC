@model Proyecto

<div class="container py-4">
    <form method="post" class="shadow-sm border rounded p-4 bg-light" enctype="multipart/form-data">
        <!-- Campos ocultos -->
        <input asp-for="IdProyecto" hidden />
        <input asp-for="ImageURL" hidden />

        <div class="row align-items-start g-4">
            <!-- Columna principal -->
            <div class="col-12 col-lg-9">
                <!-- Encabezado -->
                <div class="text-primary mb-4">
                    <h2 class="fw-bold">
                        @(Model.IdProyecto != 0 ? "Actualizar Proyecto" : "Crear Proyecto")
                    </h2>
                    <p class="text-muted mb-0">
                        Completa la información del proyecto y selecciona una imagen representativa.
                    </p>
                </div>

                <!-- Nombre del proyecto -->
                <div class="mb-3">
                    <label asp-for="NombreProyecto" class="form-label fw-semibold"></label>
                    <input asp-for="NombreProyecto" class="form-control" placeholder="Ingrese el nombre del proyecto" />
                    <span asp-validation-for="NombreProyecto" class="text-danger small"></span>
                </div>

                <!-- Imagen -->
                <div class="mb-3">
                    <label asp-for="ImageURL" class="form-label fw-semibold">Imagen del proyecto</label>
                    <input type="file" name="file" class="form-control" />
                    <span asp-validation-for="ImageURL" class="text-danger small"></span>
                </div>

                <!-- Botones de acción -->
                <div class="d-flex gap-3 mt-4">
                    @if (Model.IdProyecto != 0)
                    {
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save"></i> Actualizar
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-plus-circle"></i> Agregar
                        </button>
                    }

                    <a asp-controller="Proyecto" asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left-circle"></i> Volver a la lista
                    </a>
                </div>
            </div>

            <!-- Columna lateral con la imagen -->
            <div class="col-12 col-lg-3 text-center">
                <div class="border rounded shadow-sm p-2 bg-white">
                    <img src="@Model.ImageURL"
                         alt="Vista previa del proyecto"
                         class="img-fluid rounded mb-2"
                         style="max-height: 220px; object-fit: contain;" />
                    <div class="text-muted small">Vista previa actual</div>
                </div>
            </div>
        </div>
    </form>
</div>
