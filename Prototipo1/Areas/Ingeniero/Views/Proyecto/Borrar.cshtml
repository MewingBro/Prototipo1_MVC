@model Proyecto

<div class="container py-4">
    <form method="post" class="shadow-sm border rounded p-4 bg-light">
        <!-- Campo oculto -->
        <input asp-for="IdProyecto" hidden />

        <!-- Encabezado -->
        <div class="text-center mb-4">
            <h2 class="text-danger fw-bold">
                <i class="bi bi-exclamation-triangle-fill"></i> Borrar Proyecto
            </h2>
            <p class="text-muted mb-0">
                Estás a punto de eliminar este proyecto. Esta acción no se puede deshacer.
            </p>
        </div>

        <!-- Información del proyecto -->
        <div class="mb-3">
            <label asp-for="NombreProyecto" class="form-label fw-semibold">Nombre Proyecto</label>
            <input asp-for="NombreProyecto" disabled class="form-control bg-white" />
        </div>

        <!-- Botones -->
        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-danger px-4">
                <i class="bi bi-trash-fill"></i> Borrar
            </button>

            <a asp-controller="Proyecto" asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left-circle"></i> Volver a la lista
            </a>
        </div>
    </form>
</div>
