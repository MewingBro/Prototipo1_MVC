@model List<Recinto>
<partial name="_Notification" />
    <div class="container">

    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">Lista de Aposentos</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Recinto" asp-action="Upsert" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Agregar Recinto
            </a>
        </div>
    </div>


<table class="table table-bordered table-stripped">
    <thead>
    <tr>
        <th>
            Id de Recinto
        </th>
        <th>
            Nombre del Recinto
        </th>
                <th>
                    Nombre del Aposento
                </th>

                <th>
                    Nombre del Nivel
                </th>
                <th>
                    Nombre del Proyecto
                </th>
                <th>

                </th>
                <th>

                </th>
    </tr>
    </thead>
    <tbody>
        @foreach (var obj in Model.OrderBy(u=>u.IdRecinto))
        {
            <tr>
            <td>
                @obj.IdRecinto
            </td>
            <td>
                @obj.NombreRecinto
            </td>
                    <td>
                        @obj.Aposento.NombreAposento
                    </td>
                    <td>
                        @obj.Aposento.Nivel.NombreNivel
                    </td>
                    <td>
                        @obj.Aposento.Nivel.Proyecto.NombreProyecto
                    </td>

                    <td>
                        <a asp-controller="RecintoProducto" asp-action="Index" asp-route-IdRecinto="@obj.IdRecinto" class="btn btn-outline-secondary form-control">
                            Modificar Presupuesto del Recinto
                        </a>
                        
                    </td>

            <td>
                <div class="w-75 btn-group" role="group">
                    <a asp-controller="Recinto" asp-action="Upsert" asp-route-IdRecinto="@obj.IdRecinto" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil">Editar Recinto</i>
                    </a>
                            <a asp-controller="Recinto" asp-action="Borrar" asp-route-IdRecinto="@obj.IdRecinto" class="btn btn-danger mx-2">
                                <i class="bi bi-trash3"></i>Borrar Recinto
                            </a>
                            
                </div>
            </td>
        
        </tr>
        }
    </tbody>
</table>

</div>
