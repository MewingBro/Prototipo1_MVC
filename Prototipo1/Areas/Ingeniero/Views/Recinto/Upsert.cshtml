@model Prototipo1.Models.ViewModels.RecintoVM

<div class="container py-4">
    <form method="post" enctype="multipart/form-data" class="shadow-sm border rounded p-4 bg-light">
        <!-- Campos ocultos -->
        <input asp-for="Recinto.IdRecinto" hidden />

        <!-- Título -->
        <div class="mb-4">
            <h2 class="text-primary fw-bold">
                <i class="bi @(Model.Recinto.IdRecinto != 0 ? "bi-pencil-square" : "bi-plus-circle")"></i>
                @(Model.Recinto.IdRecinto != 0 ? "Actualizar Recinto" : "Crear Recinto")
            </h2>
            <p class="text-muted mb-0">
                Complete los datos del recinto y seleccione el aposento correspondiente.
            </p>
        </div>

        <!-- Nombre del recinto -->
        <div class="mb-3">
            <label asp-for="Recinto.NombreRecinto" class="form-label fw-semibold">Nombre Recinto</label>
            <input asp-for="Recinto.NombreRecinto" class="form-control" placeholder="Ingrese el nombre del recinto" />
            <span asp-validation-for="Recinto.NombreRecinto" class="text-danger"></span>
        </div>

        <!-- Aposento -->
        <div class="mb-3">
            <label class="form-label fw-semibold">Aposento</label>
            <select asp-for="Recinto.IdAposento" asp-items="Model.AposentoList" class="form-select">
                <option value="">--- Seleccionar Aposento ---</option>
            </select>
            <span asp-validation-for="Recinto.IdAposento" class="text-danger"></span>
        </div>

        <!-- Botones de acción -->
        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi @(Model.Recinto.IdRecinto != 0 ? "bi-save" : "bi-plus-lg")"></i>
                @(Model.Recinto.IdRecinto != 0 ? "Actualizar" : "Agregar")
            </button>

            <a asp-controller="Recinto" asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left-circle"></i> Volver a la lista
            </a>
        </div>
    </form>
</div>
