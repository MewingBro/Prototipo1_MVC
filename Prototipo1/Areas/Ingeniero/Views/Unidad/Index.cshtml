@model List<Unidad>
<partial name="_Notification" />
<div class="container">

    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">Lista de Unidades de productos</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Unidad" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Agregar Unidad
            </a>
        </div>
    </div>


    <table class="table table-bordered table-stripped">
        <thead>
            <tr>
                <th>
                    Id de Unidad
                </th>
                <th>
                    Nombre de la Unidad
                </th>
                <th>

                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model.OrderBy(u => u.IdUnidad))
            {
                <tr>
                    <td>
                        @obj.IdUnidad
                    </td>
                    <td>
                        @obj.NombreUnidad
                    </td>
                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Unidad" asp-action="Editar" asp-route-idUnidad="@obj.IdUnidad" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil">Editar Unidad</i>
                            </a>
                            <a asp-controller="Unidad" asp-action="Borrar" asp-route-idUnidad="@obj.IdUnidad" class="btn btn-danger mx-2">
                                <i class="bi bi-trash3"></i>Borrar Unidad
                            </a>

                        </div>
                    </td>

                </tr>
            }
        </tbody>
    </table>

</div>
