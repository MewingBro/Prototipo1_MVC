@model Unidad

<form method="post" class="row justify-content-center">
    <input asp-for="IdUnidad" hidden />

    <div class="col-12 col-md-8 col-lg-6">
        <div class="border p-4 mt-5 rounded-3 shadow-sm bg-light">
            <div class="text-center pb-3">
                <h2 class="text-primary fw-bold">
                    <i class="bi bi-pencil-square me-2"></i> Editar Unidad
                </h2>
                <p class="text-muted mb-0">Modifique los datos necesarios y guarde los cambios.</p>
            </div>

            <hr class="my-3" />

            <div class="mb-3">
                <label asp-for="NombreUnidad" class="form-label fw-semibold">Nombre Unidad</label>
                <input asp-for="NombreUnidad" class="form-control" placeholder="Ej: Metro, Kilogramo, Litro..." />
                <span asp-validation-for="NombreUnidad" class="text-danger small"></span>
            </div>

            <div class="row mt-4">
                <div class="col-12 col-md-6 mb-2 mb-md-0">
                    <button type="submit" class="btn btn-primary w-100 shadow-sm" id="btnEditarUnidad">
                        <i class="bi bi-save-fill me-1"></i> Guardar Cambios
                    </button>
                </div>
                <div class="col-12 col-md-6">
                    <a asp-controller="Unidad" asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left-circle me-1"></i> Volver a la lista
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById("btnEditarUnidad")?.addEventListener("click", function (e) {
            const input = document.querySelector("[name='NombreUnidad']");
            if (!input.value.trim()) {
                e.preventDefault();
                alert("Por favor, ingrese un nombre de unidad antes de guardar los cambios.");
                input.focus();
            }
        });
    </script>
}
