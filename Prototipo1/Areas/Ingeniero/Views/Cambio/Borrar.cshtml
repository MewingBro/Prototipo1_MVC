@model Recinto

<form method="post">
    <input asp-for="IdRecinto" hidden />
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">
                Borrar Recinto
            </h2>
        </div>

        <div class="mb-3 row p-1">
            <label asp-for="NombreRecinto" class="p-0"></label>
            <input asp-for="NombreRecinto" disabled class="form-control" />
        </div>

        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">Borrar</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Recinto" asp-action="Index" class="btn btn-outline-secondary form-control">
                    Volver a la lista
                </a>
            </div>
        </div>
    </div>
</form>
