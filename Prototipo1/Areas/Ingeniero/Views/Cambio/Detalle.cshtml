@model List<Prototipo1.Models.ViewModels.CambioDetalleVM>

@{
    ViewData["Title"] = "Detalle de Solicitud de Cambio";
}

<div class="container mt-4">
    <h2 class="text-primary mb-3">Detalle de Solicitud de Cambio</h2>

    <table class="table table-bordered table-striped">
        <thead class="table-light">
            <tr>
                <th>Producto</th>
                <th>Cantidad Solicitada</th>
                <th>Existencias Actuales Presupuestadas</th>
                <th>Inventario del Proyecto</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.SeExcede ? "table-danger" : "")">
                    <td>@item.NombreProducto</td>
                    <td>@item.CantidadDisminuida</td>
                    <td>@item.ExistenciasActuales</td>
                    <td>@item.InventarioProyecto</td>
                </tr>
            }
        </tbody>
    </table>

    
    <div class="mt-4 text-end">
        @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Bodeguero)) {
        <form asp-action="Aprobar" method="post" class="d-inline">
            <input type="hidden" name="IdCambio" value="@ViewBag.IdCambio" />
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle"></i> Aprobar Solicitud
            </button>
        </form>

        <form asp-action="Rechazar" method="post" class="d-inline">
            <input type="hidden" name="IdCambio" value="@ViewBag.IdCambio" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-x-circle"></i> Rechazar Solicitud
            </button>
        </form>
        }

        <a asp-action="Index" class="btn btn-secondary ms-2">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>
