@model List<Prototipo1.Models.ViewModels.CambioPresupuestoVM>
@{
    Layout = null;
    var fecha = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Impresión - Reporte de Cambios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            margin: 40px;
            color: #000;
        }

        .logo {
            max-height: 70px;
        }

        .titulo {
            text-align: center;
            margin-bottom: 20px;
        }

        table {
            font-size: 13px;
        }
        .media print {
            .no-print

        {
            display: none;
        }

        body {
            margin: 20px;
        }

        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <!-- Encabezado -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <img src="~/Images/logo.png" class="logo" alt="Logo Empresa" />
            
        </div>
        <div>
            <h5 class="mb-0">Reporte de Cambios de Presupuesto</h5>
            <small>Fecha: @fecha</small><br />
            <small>Proyecto: @ViewBag.Proyecto</small>
        </div>

        <!-- Tabla -->
        <table class="table table-bordered table-striped text-center align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>ID Factura</th>
                    <th>Código Producto</th>
                    <th>Nombre Producto</th>
                    <th>Presupuesto</th>
                    <th>Unidades Entregadas</th>
                    <th>Sobregiro</th>
                    <th>Nivel</th>
                    <th>Aposento</th>
                    <th>Recinto</th>
                    <th>Comentario</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    double Suma = (@item.CantidadDisminuida - @item.Presupuesto);
                    <tr>
                        <td>@item.IdFactura</td>
                        <td>@item.CodigoProducto</td>
                        <td class="text-start">@item.NombreProducto</td>
                        <td>@item.Presupuesto</td>
                        <td>@item.CantidadDisminuida</td>
                        <td class="fw-bold @(item.Sobregiro > 0 ? "text-danger" : "text-success")">@Suma</td>
                        <td>@item.Nivel</td>
                        <td>@item.Aposento</td>
                        <td>@item.Recinto</td>
                        <td class="text-start">@item.Comentario</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="text-center mt-4 no-print">
            <button class="btn btn-primary" onclick="window.print()">
                <i class="bi bi-printer"></i> Imprimir
            </button>
            <a asp-action="ReporteCambios" class="btn btn-outline-secondary">
                Volver
            </a>
        </div>
    </div>
</body>
</html>
